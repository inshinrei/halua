{
    "name": "halua",
    "version": "3.0.0",
    "description": "Tiny zero-dependency logger with pluggable dispatchers, child contexts, minor levels (e.g. INFO+5) and safe formatting",
    "type": "module",
    "main": "lib/index.cjs",
    "module": "lib/index.js",
    "types": "lib/index.d.ts",
    "exports": {
        ".": {
            "import": {
                "types": "./lib/index.d.ts",
                "default": "./lib/index.js"
            },
            "require": {
                "types": "./lib/index.d.cts",
                "default": "./lib/index.cjs"
            }
        }
    },
    "files": [
        "lib",
        "README.md",
        "LICENSE",
        "AGENTS.md"
    ],
    "scripts": {
        "test": "vitest",
        "dev": "vitest",
        "bench": "node benchmarks/main_bench.js",
        "build": "tsup",
        "prepare": "pnpm run test run && pnpm run build",
        "format:check": "prettier --check \"**/*.{ts,js,json,md,yml,yaml}\"",
        "format": "prettier --write \"**/*.{ts,js,json,md,yml,yaml}\"",
        "lint": "pnpm run format:check",
        "postversion": "git push && git push --tags"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/inshinrei/halua.git"
    },
    "keywords": [
        "logger",
        "logging",
        "node",
        "console",
        "web",
        "json logs"
    ],
    "author": "inshinrei",
    "license": "MIT",
    "bugs": {
        "url": "https://github.com/inshinrei/halua/issues"
    },
    "homepage": "https://github.com/inshinrei/halua#readme",
    "devDependencies": {
        "@types/node": "^24.9.1",
        "prettier": "^3.6.1",
        "tinybench": "^5.0.0",
        "ts-node": "^10.9.2",
        "tsup": "^8.5.0",
        "typescript": "^5.8.3",
        "vitest": "^3.2.4"
    },
    "publishConfig": {
        "access": "public"
    }
}
