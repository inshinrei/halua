{
    "name": "halua",
    "version": "4.0.1",
    "description": "Tiny zero-dependency logger with pluggable dispatchers, child contexts, minor levels (e.g. INFO+5) and safe formatting",
    "type": "module",
    "main": "lib/index.cjs",
    "module": "lib/index.js",
    "types": "lib/index.d.ts",
    "exports": {
        ".": {
            "import": {
                "types": "./lib/index.d.ts",
                "default": "./lib/index.js"
            },
            "require": {
                "types": "./lib/index.d.ts",
                "default": "./lib/index.cjs"
            }
        }
    },
    "files": [
        "lib",
        "README.md",
        "LICENSE"
    ],
    "scripts": {
        "test": "vitest",
        "dev": "vitest",
        "bench": "node benchmarks/main-bench.js",
        "build": "vite build",
        "prepare": "pnpm run lint && pnpm run test run && pnpm run build",
        "format:check": "prettier --check \"**/*.{ts,js,json,md,yml,yaml}\"",
        "format": "prettier --write \"**/*.{ts,js,json,md,yml,yaml}\"",
        "lint": "pnpm run format:check",
        "postversion": "git push && git push --tags"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/inshinrei/halua.git"
    },
    "keywords": [
        "logger",
        "logging",
        "node",
        "console",
        "web",
        "json logs"
    ],
    "author": "inshinrei",
    "license": "MIT",
    "bugs": {
        "url": "https://github.com/inshinrei/halua/issues"
    },
    "homepage": "https://github.com/inshinrei/halua#readme",
    "devDependencies": {
        "@microsoft/api-extractor": "7.58.7",
        "@types/node": "25.9.1",
        "prettier": "3.8.3",
        "tinybench": "6.0.2",
        "ts-node": "10.9.2",
        "typescript": "6.0.3",
        "vite": "6.4.2",
        "vite-plugin-dts": "5.0.1",
        "vitest": "4.1.7"
    },
    "publishConfig": {
        "access": "public"
    }
}
