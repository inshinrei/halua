{
    "compilerOptions": {
        "target": "esnext",
        "module": "esnext",
        "lib": ["esnext", "dom"],
        "types": ["node"],
        "moduleResolution": "node",
        "ignoreDeprecations": "6.0",
        "declaration": true,
        "outDir": "./lib",
        "skipLibCheck": true,
        "esModuleInterop": true,
        "strict": true,
        "strictNullChecks": true
    },
    "include": ["src/**/*.ts"],
    "exclude": ["node_modules", "src/**/*-unit.ts"]
}
